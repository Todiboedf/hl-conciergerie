# ============================================================
# H&L Conciergerie — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs.
# Ne JAMAIS committer .env.local.
# ============================================================

# Claude API — moteur du diagnostic de rentabilité
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Resend — emails transactionnels (formulaire contact + diagnostic lead)
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=contact@hlconciergerie.fr
RESEND_TO_EMAIL=contact@hlconciergerie.fr

# URL publique du site (utilisée pour Open Graph, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=https://hlconciergerie.fr

# Microsoft Clarity — analytics comportementales
# https://clarity.microsoft.com
NEXT_PUBLIC_CLARITY_ID=
