# ============================================================
# H&L Conciergerie — Variables d'environnement
# ============================================================
# Copier ce fichier en .env.local et remplir les valeurs.
# Ne JAMAIS committer .env.local.
# Aucune variable n'est obligatoire en développement :
# le site fonctionne avec des fallbacks quand les clés sont absentes.
# ============================================================

# Claude API — moteur du diagnostic de rentabilité (Session 4, pas encore utilisée).
# Obtenir une clé : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Resend — envoi des emails du formulaire de contact.
# Optionnelle en dev : sans cette clé, le formulaire bascule en fallback
# local qui log la soumission au lieu de l'envoyer par email.
# Obtenir une clé : https://resend.com/api-keys
RESEND_API_KEY=

# Expéditeur des emails Resend. Garder "onboarding@resend.dev" tant que
# le domaine hl-conciergerie.com n'est pas vérifié côté Resend.
RESEND_FROM_EMAIL=onboarding@resend.dev

# Destinataire des soumissions du formulaire de contact.
# Exemple : contact@hl-conciergerie.com
RESEND_TO_EMAIL=

# URL publique du site, utilisée pour les meta Open Graph, canonicals
# et sitemaps. En prod, mettre l'URL Vercel ou le domaine custom.
# Exemple : https://hl-conciergerie.com
NEXT_PUBLIC_SITE_URL=

# Microsoft Clarity — analytics comportementales (optionnel).
# Laisser vide pour désactiver le script.
# Obtenir un ID : https://clarity.microsoft.com
NEXT_PUBLIC_CLARITY_ID=
